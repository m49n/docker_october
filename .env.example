APP_NAME="October CMS"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://example.com
APP_LOCALE=en

ACTIVE_THEME=demo
BACKEND_URI=admin
CMS_ROUTE_CACHE=true
CMS_ASSET_CACHE=true
LINK_POLICY=secure
DEFAULT_FILE_MASK=664
DEFAULT_FOLDER_MASK=775

DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=5432
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

CACHE_STORE=redis
CACHE_DRIVER=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120

REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

LOG_CHANNEL=stderr

MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@example.com
MAIL_FROM_NAME="${APP_NAME}"

KAFKA_BROKERS=
KAFKA_SECURITY_PROTOCOL=plaintext
KAFKA_SASL_MECHANISM=
KAFKA_SASL_USERNAME=
KAFKA_SASL_PASSWORD=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

HTTP_PORT=80
IMAGE_TAG=latest
APP_IMAGE=registry.example.com/project/october-app
NGINX_IMAGE=registry.example.com/project/october-nginx

# Build/install secret only. Do not pass this as a runtime env variable in production.
OCTOBER_ACCOUNT_EMAIL=
OCTOBER_LICENSE_KEY=
